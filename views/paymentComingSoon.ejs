<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout Coming Soon</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

  <!-- Background Overlay -->
  <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center px-4">

    <!-- Modal -->
    <div class="bg-white rounded-3xl shadow-2xl p-10 max-w-md w-full text-center">

      <!-- Icon -->
      <div class="text-5xl mb-4">
        🎉
      </div>

      <!-- Heading -->
      <h1 class="text-4xl font-serif text-gray-800 mb-4">
        Almost There!
      </h1>

      <!-- Description -->
      <p class="text-gray-600 text-lg leading-relaxed mb-8">
        Payment options are coming soon. We're working hard to bring you a secure and seamless checkout experience.
      </p>

      <!-- Button -->
      <a
        href="/shop"
        class="inline-block bg-black hover:bg-green-700 text-white font-semibold px-8 py-3 rounded-xl transition duration-300 shadow-lg"
      >
        Continue Shopping
      </a>

    </div>

  </div>

</body>
</html>